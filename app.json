{
  "expo": {
    "name": "ParcialApp",
    "slug": "ParcialApp",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "plugins": [
      "expo-notifications",
      [
        "expo-image-picker",
        {
          "photosPermission": "La app accede a tus fotos para asociar una imagen al producto.",
          "cameraPermission": "La app usa la camara para tomar una foto del producto."
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "La app usa tu ubicacion para registrar el comercio donde comprar."
        }
      ],
      [
        "expo-contacts",
        {
          "contactsPermission": "La app accede a tus contactos para asociar un proveedor al producto."
        }
      ],
      "expo-calendar"
    ],
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "permissions": [
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.SCHEDULE_EXACT_ALARM"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    }
  }
}
